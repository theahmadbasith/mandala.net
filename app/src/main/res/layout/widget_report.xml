<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="UseAppTint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <!-- The actual physical Widget Card with Rounded Background -->
    <!-- Set to wrap_content and center_vertical to keep it perfectly slim and compact -->
    <LinearLayout
        android:id="@+id/widget_report_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/widget_background"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Row 1: Header Row with Logo, Title, and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_widget_edit"
                android:contentDescription="Sipedas Icon"
                android:tint="@color/widget_icon_tint" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_marginStart="4dp"
                android:text="SIPEDAS PATROLI"
                android:textColor="@color/widget_text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <!-- Status Indicator Pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/widget_inner_card_bg"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp">

                <TextView
                    android:id="@+id/widget_report_status_dot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● "
                    android:textColor="#10B981"
                    android:textSize="7sp" />

                <TextView
                    android:id="@+id/widget_report_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siap"
                    android:textColor="#10B981"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Single-line Draft Preview (Sejajar/Sebaris Saja) -->
        <LinearLayout
            android:id="@+id/btn_widget_draft_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_inner_card_bg"
            android:clickable="true"
            android:focusable="true"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRAF: "
                android:textColor="@color/widget_text_secondary"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_widget_draft_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PATROLI SIPEDAS: Situasi aman, kondusif, dan terkendali."
                android:textColor="@color/widget_text_primary"
                android:textSize="9sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Row 3: Action Buttons (Kamera, Galeri, Tempel) in One Responsive Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Camera Button -->
            <LinearLayout
                android:id="@+id/btn_widget_camera"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/widget_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginRight="4dp"
                android:layout_marginEnd="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_widget_camera"
                    android:tint="@color/widget_icon_tint"
                    android:contentDescription="Kamera" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kamera"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:layout_marginLeft="3dp"
                    android:layout_marginStart="3dp" />
            </LinearLayout>

            <!-- Gallery Button -->
            <LinearLayout
                android:id="@+id/btn_widget_gallery"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/widget_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginRight="4dp"
                android:layout_marginEnd="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_widget_gallery"
                    android:tint="@color/widget_icon_tint"
                    android:contentDescription="Galeri" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Galeri"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:layout_marginLeft="3dp"
                    android:layout_marginStart="3dp" />
            </LinearLayout>

            <!-- Paste/Tempel Button -->
            <LinearLayout
                android:id="@+id/btn_widget_paste"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/widget_btn_primary"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_widget_paste"
                    android:tint="#FFFFFF"
                    android:contentDescription="Tempel" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tempel"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:layout_marginLeft="3dp"
                    android:layout_marginStart="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
