<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="4"
    android:background="@drawable/widget_bg"
    android:paddingLeft="4dp"
    android:paddingRight="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical">

    <!-- Column 1: Force -->
    <LinearLayout
        android:id="@+id/widget_btn_force"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_widget_force"
            android:contentDescription="Force LTE/5G" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Force 5G"
            android:textColor="@color/widget_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Column 2: Speed Test -->
    <LinearLayout
        android:id="@+id/widget_btn_speed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_widget_speed"
            android:contentDescription="Speed Test" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speed"
            android:textColor="@color/widget_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Column 3: Redial -->
    <LinearLayout
        android:id="@+id/widget_btn_redial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_widget_redial"
            android:contentDescription="Auto Redial" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Redial"
            android:textColor="@color/widget_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Column 4: Firewall (Dynamic Status) -->
    <LinearLayout
        android:id="@+id/widget_btn_firewall"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp">

        <ImageView
            android:id="@+id/widget_firewall_icon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_shield_inactive"
            android:contentDescription="Firewall Toggle" />

        <TextView
            android:id="@+id/widget_firewall_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FW: Off"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>
